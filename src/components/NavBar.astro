---
// src/components/NavBar.astro
import { navLinks, mobileNav } from '../data/es/nav.ts';
import LanguageToggle from './LanguageToggle.jsx';

export interface Props {
  lang?: 'es' | 'en';
}

const { lang = 'es' } = Astro.props;
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
const currentPath = Astro.url.pathname;
const links = lang === 'en'
  ? (await import('../data/en/nav.ts')).navLinks
  : navLinks;
const mobile = lang === 'en'
  ? (await import('../data/en/nav.ts')).mobileNav
  : mobileNav;
const homeHref = lang === 'en' ? `${b}/en/` : `${b}/`;
const bookHref = lang === 'en' ? `${b}/en/booking` : `${b}/reservas`;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-zinc-900/75 backdrop-blur-xl border-b border-white/8" style="backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);">
  <nav class="max-w-7xl mx-auto px-6 h-[68px] flex items-center justify-between">

    <a href={homeHref} class="flex items-center shrink-0">
      <img src={`${b}/Logo/LOGO_Nego_Blanco.svg`} alt="Infinity Gun Club" class="h-28 w-auto" style="mix-blend-mode: screen;" />
    </a>

    <ul class="hidden md:flex items-center gap-8">
      {links.map((link) => (
        <li>
          <a
            href={b + link.href}
            class="text-[11px] font-bold uppercase tracking-[0.18em] text-zinc-400 hover:text-white transition-colors duration-200"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <div class="flex items-center gap-5">
      <LanguageToggle currentPath={currentPath} client:load />
      <a
        href={bookHref}
        class="hidden md:inline-block text-[11px] font-black uppercase tracking-[0.18em] bg-primary text-black px-5 py-2.5 hover:bg-primary-dark transition-colors duration-200"
      >
        {lang === 'en' ? 'BOOK NOW' : 'RESERVAR'}
      </a>
    </div>
  </nav>
</header>

<div class="h-[68px]"></div>

<nav class="md:hidden fixed bottom-0 left-0 right-0 z-[100] bg-black/60 backdrop-blur-xl border-t border-white/8"
     style="padding-bottom: env(safe-area-inset-bottom)">
  <ul class="flex justify-around items-center h-14">
    {mobile.map((item) => (
      <li>
        <a
          href={b + item.href}
          class="flex flex-col items-center gap-0.5 text-zinc-600 hover:text-primary transition-colors px-3 py-1"
        >
          <span class="w-5 h-5 block [&>svg]:w-full [&>svg]:h-full"><Fragment set:html={item.icon} /></span>
          <span class="text-[9px] font-bold uppercase tracking-wider">{item.label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<div class="md:hidden h-14"></div>
