---
// src/components/StickyCTA.astro
export interface Props {
  lang?: 'es' | 'en';
  href?: string;
}
const { lang = 'es', href } = Astro.props;
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
const link = href ?? (lang === 'en' ? `${b}/en/booking` : `${b}/reservas`);
const label = lang === 'en' ? 'BOOK NOW →' : 'RESERVA AHORA →';
---

<a
  id="sticky-cta"
  href={link}
  class="md:hidden fixed left-0 right-0 z-[99] bg-primary text-black font-black text-[11px] uppercase tracking-[0.25em] py-3.5 text-center transition-transform translate-y-full"
  style="bottom: 56px"
  aria-label={label}
>
  {label}
</a>

<script>
  const cta = document.getElementById('sticky-cta');
  const footer = document.querySelector('footer');
  if (cta) {
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY > 300;
      const nearFooter = footer ? window.scrollY + window.innerHeight >= footer.offsetTop : false;
      cta.classList.toggle('translate-y-full', !scrolled || nearFooter);
    }, { passive: true });
  }
</script>
