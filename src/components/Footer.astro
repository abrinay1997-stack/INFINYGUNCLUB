---
// src/components/Footer.astro
export interface Props {
  lang?: 'es' | 'en';
}
const { lang = 'es' } = Astro.props;
const b = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---

<footer class="bg-zinc-950 border-t border-white/5">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">

      <div>
        <img src={`${b}/Logo/LOGO_Nego_Blanco.svg`} alt="Infinity Gun Club" class="h-20 w-auto mb-5" style="mix-blend-mode: screen;" />
        <p class="text-zinc-500 text-sm leading-relaxed">
          {lang === 'en'
            ? "Panama's largest shooting range. Safe, professional, for all levels."
            : "El polígono de tiro más grande de Panamá. Seguro, profesional, para todos los niveles."}
        </p>
      </div>

      <div>
        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-white mb-5">{lang === 'en' ? 'Services' : 'Servicios'}</p>
        <ul class="space-y-3 text-sm text-zinc-500">
          <li><a href={lang === 'en' ? `${b}/en/civilians` : `${b}/civiles`} class="hover:text-primary transition-colors">{lang === 'en' ? 'Civilian Experience' : 'Experiencias Civiles'}</a></li>
          <li><a href={lang === 'en' ? `${b}/en/corporate` : `${b}/corporativo`} class="hover:text-primary transition-colors">{lang === 'en' ? 'Corporate Events' : 'Eventos Corporativos'}</a></li>
          <li><a href={lang === 'en' ? `${b}/en/government` : `${b}/gobierno`} class="hover:text-primary transition-colors">{lang === 'en' ? 'Government Training' : 'Training Gobierno'}</a></li>
          <li><a href={lang === 'en' ? `${b}/en/facilities` : `${b}/instalaciones`} class="hover:text-primary transition-colors">{lang === 'en' ? 'Facilities' : 'Instalaciones'}</a></li>
        </ul>
      </div>

      <div>
        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-white mb-5">{lang === 'en' ? 'Contact' : 'Contacto'}</p>
        <ul class="space-y-3 text-sm text-zinc-500">
          <li>Panama City, Panamá</li>
          <li>{lang === 'en' ? 'Phone: PENDING' : 'Tel: PENDIENTE'}</li>
          <li>reservas@infinitygunclub.pa</li>
          <li>{lang === 'en' ? 'Mon–Sun 8am–6pm' : 'Lun–Dom 8am–6pm'}</li>
        </ul>
      </div>

      <div>
        <p class="text-[10px] font-black uppercase tracking-[0.3em] text-white mb-5">{lang === 'en' ? 'Follow' : 'Síguenos'}</p>
        <a href="https://www.instagram.com/infinitygunclub" target="_blank" rel="noopener noreferrer"
          class="text-sm text-zinc-500 hover:text-primary transition-colors block mb-8">
          @infinitygunclub
        </a>
        <a href={lang === 'en' ? `${b}/en/booking` : `${b}/reservas`}
          class="inline-block text-[11px] font-black uppercase tracking-[0.2em] bg-primary text-black px-6 py-3 hover:bg-primary-dark transition-colors">
          {lang === 'en' ? 'BOOK NOW' : 'RESERVAR'}
        </a>
      </div>

    </div>

    <div class="border-t border-white/5 mt-14 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <span class="text-[11px] text-zinc-600 uppercase tracking-widest">© {year} Infinity Gun Club</span>
      <span class="text-[11px] text-zinc-700 uppercase tracking-widest">{lang === 'en' ? 'All rights reserved' : 'Todos los derechos reservados'}</span>
    </div>
  </div>
</footer>
