---
// src/components/ContactMap.astro
export interface Props {
  lang?: 'es' | 'en';
}
const { lang = 'es' } = Astro.props;
---

<section class="py-28 bg-black">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-center gap-3 mb-16">
      <div class="w-6 h-px bg-primary"></div>
      <p class="text-primary text-[10px] font-black uppercase tracking-[0.35em]">
        {lang === 'en' ? 'FIND US' : 'ENCUÉNTRANOS'}
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-0">
      <div class="h-72 lg:h-full min-h-[360px] overflow-hidden bg-zinc-900">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d897.3412612322087!2d-79.50817750314698!3d9.025189482459831!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8faca9061b022101%3A0x35f6d9fef2f5de6b!2sINFINITY%20GUN%20CLUB!5e1!3m2!1ses!2spa!4v1775141988078!5m2!1ses!2spa"
          width="100%"
          height="100%"
          style="border:0; filter: grayscale(100%) contrast(1.1)"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Infinity Gun Club — Ubicación"
        ></iframe>
      </div>

      <div class="bg-zinc-950 p-12 flex flex-col justify-center gap-8">
        <div>
          <p class="text-[10px] font-black uppercase tracking-[0.3em] text-primary mb-2">
            {lang === 'en' ? 'Location' : 'Ubicación'}
          </p>
          <p class="text-zinc-300 text-sm">Panama City, Panamá</p>
        </div>
        <div>
          <p class="text-[10px] font-black uppercase tracking-[0.3em] text-primary mb-2">
            {lang === 'en' ? 'Hours' : 'Horarios'}
          </p>
          <p class="text-zinc-300 text-sm">
            {lang === 'en' ? 'Monday – Sunday: 8:00 AM – 6:00 PM' : 'Lunes – Domingo: 8:00 AM – 6:00 PM'}
          </p>
        </div>
        <div>
          <p class="text-[10px] font-black uppercase tracking-[0.3em] text-primary mb-2">Instagram</p>
          <a href="https://www.instagram.com/infinitygunclub" target="_blank" rel="noopener noreferrer"
            class="text-zinc-300 text-sm hover:text-primary transition-colors">@infinitygunclub</a>
        </div>
        <div>
          <p class="text-[10px] font-black uppercase tracking-[0.3em] text-primary mb-2">Email</p>
          <p class="text-zinc-300 text-sm">reservas@infinitygunclub.pa</p>
        </div>
      </div>
    </div>
  </div>
</section>
