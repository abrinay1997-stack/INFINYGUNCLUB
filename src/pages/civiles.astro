---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import StickyCTA from '../components/StickyCTA.astro';
import BookingForm from '../components/BookingForm.jsx';
import TrustSignals from '../components/TrustSignals.astro';
import FAQ from '../components/FAQ.astro';

const b = import.meta.env.BASE_URL.replace(/\/$/, '');

const faqCiviles = [
  { q: '¿Qué armas puedo usar?', a: 'Pistolas 9mm, .45 ACP, revólveres, rifles AR-15 y escopetas según el paquete elegido.' },
  { q: '¿Incluye instructor?', a: 'Todos los paquetes incluyen instructor certificado durante toda la sesión.' },
  { q: '¿Cuánto tiempo dura?', a: 'Las sesiones duran entre 1 y 3 horas según el paquete. Recomendamos llegar 15 minutos antes.' },
];
---

<Layout
  title="Experiencias de Tiro para Civiles — Infinity Gun Club Panamá"
  description="Vive la adrenalina del tiro con seguridad total. Paquetes para principiantes y avanzados en el polígono más grande de Panamá."
  lang="es"
  hreflangEs="https://infinitygunclub.netlify.app/civiles"
  hreflangEn="https://infinitygunclub.netlify.app/en/civilians"
>
  <NavBar lang="es" />
  <StickyCTA lang="es" href={`${b}/reservas?tipo=civil`} />

  <section class="min-h-[70vh] flex items-end bg-black relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-r from-black via-black/70 to-black/20 z-10"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent z-10"></div>
    <div class="absolute inset-0 bg-cover bg-center opacity-50" style={`background-image: url('${b}/images/civiles-bg.jpg')`}></div>
    <div class="relative z-20 max-w-7xl mx-auto px-6 pb-20">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-6 h-px bg-primary"></div>
        <p class="text-primary text-[10px] font-black uppercase tracking-[0.35em]">👤 CIVILES</p>
      </div>
      <h1 class="font-display text-[70px] md:text-[100px] text-white leading-[0.9] mb-6">VIVE LA<br>ADRENALINA</h1>
      <p class="text-zinc-400 text-base mb-10 max-w-sm">Para principiantes y avanzados. Instructor incluido. Seguridad total.</p>
      <a href={`${b}/reservas?tipo=civil`} class="inline-block bg-primary text-black font-black text-[11px] uppercase tracking-[0.25em] px-8 py-4 hover:bg-primary-dark transition-colors">RESERVA MI EXPERIENCIA</a>
    </div>
  </section>

  <section class="py-24 bg-zinc-950">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-14">
        <div class="w-6 h-px bg-primary"></div>
        <p class="text-primary text-[10px] font-black uppercase tracking-[0.35em]">NUESTROS PAQUETES</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-white/5">
        {[
          { name: 'BÁSICO', price: '$35', bullets: ['50 disparos', 'Pistola 9mm', 'Instructor incluido', 'Equipo de seguridad'] },
          { name: 'INTERMEDIO', price: '$65', bullets: ['100 disparos', '2 armas a elegir', 'Instructor incluido', 'Equipo + fotos'] },
          { name: 'PRO', price: '$110', bullets: ['200 disparos', '4 armas a elegir', 'Video de la sesión', 'Certificado de tiro'] },
        ].map((pkg) => (
          <div class="p-10 flex flex-col gap-6">
            <div>
              <h3 class="font-display text-4xl text-primary mb-1">{pkg.name}</h3>
              <div class="font-display text-5xl text-white">{pkg.price}</div>
            </div>
            <ul class="space-y-3 flex-1">
              {pkg.bullets.map(bullet => (
                <li class="text-zinc-500 text-sm flex gap-3">
                  <span class="text-primary text-xs mt-0.5">✓</span>{bullet}
                </li>
              ))}
            </ul>
            <a href={`${b}/reservas?tipo=civil`} class="inline-block bg-primary text-black font-black text-[11px] uppercase tracking-[0.2em] px-6 py-3 text-center hover:bg-primary-dark transition-colors">RESERVAR</a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-black">
    <div class="max-w-2xl mx-auto px-6">
      <div class="flex items-center gap-3 mb-12">
        <div class="w-6 h-px bg-primary"></div>
        <p class="text-primary text-[10px] font-black uppercase tracking-[0.35em]">RESERVA AHORA</p>
      </div>
      <BookingForm lang="es" client:visible />
    </div>
  </section>

  <FAQ items={faqCiviles} title="PREGUNTAS — CIVILES" />
  <TrustSignals lang="es" />
  <Footer lang="es" />
</Layout>
